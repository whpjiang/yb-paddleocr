MEDICAL_AD_CONFIG_PATH=config/config.yaml
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True
MEDICAL_AD_OSS_ENABLED=false
MEDICAL_AD_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
MEDICAL_AD_OSS_BUCKET_NAME=your-bucket
MEDICAL_AD_OSS_ACCESS_KEY_ID=your-access-key-id
MEDICAL_AD_OSS_ACCESS_KEY_SECRET=your-access-key-secret
MEDICAL_AD_OSS_PREFIX=medical-ad-ocr-tools/dev
MEDICAL_AD_OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
MEDICAL_AD_TEXT_DETECTION_MODEL_NAME=
MEDICAL_AD_TEXT_RECOGNITION_MODEL_NAME=
MEDICAL_AD_TEXT_DETECTION_MODEL_DIR=models/ocr/PP-OCRv5_mobile_det
MEDICAL_AD_TEXT_RECOGNITION_MODEL_DIR=models/ocr/PP-OCRv5_mobile_rec
MEDICAL_AD_TEXTLINE_ORIENTATION_MODEL_DIR=
MEDICAL_AD_FOCUS_RETRY_ENABLED=true
MEDICAL_AD_FOCUS_RETRY_MAX_REGIONS=1
MEDICAL_AD_FOCUS_RETRY_SCALE=1.8
MEDICAL_AD_FOCUS_RETRY_MIN_REGION_SCORE=0.55
MEDICAL_AD_FOCUS_RETRY_MIN_KEYWORD_HITS=2
MEDICAL_AD_FOCUS_RETRY_MID_RISK_MIN=40
MEDICAL_AD_FOCUS_RETRY_MID_RISK_MAX=69
MEDICAL_AD_FOCUS_RETRY_ENABLE_SHARPEN=true
MEDICAL_AD_FOCUS_RETRY_ENABLE_CONTRAST=true
MEDICAL_AD_FOCUS_RETRY_ENABLE_ROTATE=false
